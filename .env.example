# BranCodeX Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Railway injects DATABASE_URL automatically in production)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/brancodex

# CORS (both www and non-www; localhost:3000 is added automatically in dev)
ALLOWED_ORIGINS=https://www.brancodex.com,https://brancodex.com

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# JWT - use a long random string
JWT_SECRET=replace_with_a_long_random_secret_string_here

# Admin dashboard login
# ADMIN_EMAIL defaults to contact@brancodex.com if not set
ADMIN_EMAIL=contact@brancodex.com
# ADMIN_PASSWORD: plain text for first run, or a bcrypt hash ($2b$12$...)
ADMIN_PASSWORD=replace_with_your_admin_password_here
# ADMIN_SECRET: the bearer token returned after login and used for API calls
ADMIN_SECRET=replace_with_your_admin_secret_here
